generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  name      String
  class     Int
  board     String   @default("CBSE")
  language  String   @default("hi")
  role      Role     @default(STUDENT)
  xpTotal   Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  streak          Streak?
  progress        Progress[]
  placementResult PlacementResult[]
  parentId        String?
  parent          User?     @relation("ParentChild", fields: [parentId], references: [id])
  children        User[]    @relation("ParentChild")
}

model Streak {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentDays Int      @default(0)
  longestDays Int      @default(0)
  lastActive  DateTime @default(now())
  shields     Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Content {
  id          String      @id @default(cuid())
  title       String
  titleHi     String
  subject     String
  class       Int
  chapter     Int
  topic       Int
  type        ContentType
  videoUrl    String?
  muxAssetId  String?
  durationSec Int?
  xpReward    Int         @default(10)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  progress Progress[]
  quizzes  Quiz[]
}

model Quiz {
  id         String   @id @default(cuid())
  contentId  String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  questionEn String
  questionHi String
  options    Json
  answerIdx  Int
  difficulty Int      @default(1)
  xpReward   Int      @default(5)
  createdAt  DateTime @default(now())
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  score       Int?
  xpEarned    Int       @default(0)
  hintsUsed   Int       @default(0)
  completedAt DateTime?
  nextReview  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, contentId])
}

model PlacementResult {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  placedLevel Int
  score       Float
  createdAt   DateTime @default(now())
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("web")
  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  PARENT
  TEACHER
  ADMIN
}

enum ContentType {
  VIDEO
  QUIZ
  SUMMARY
  PRACTICE
}
